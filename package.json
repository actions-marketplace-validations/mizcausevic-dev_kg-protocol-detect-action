{
  "name": "kg-protocol-detect-action",
  "version": "0.1.0",
  "description": "GitHub Action that scans a directory of JSON documents, identifies which Kinetic Gain Suite protocol each one belongs to via kg-protocol-detect, and writes a summary + optional fail-on-unknown gate.",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/kg-protocol-detect-action"
  },
  "keywords": [
    "github-action",
    "actions",
    "kinetic-gain-suite",
    "ai-governance",
    "protocol-detection",
    "agentcards",
    "mcp",
    "otel-genai",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
